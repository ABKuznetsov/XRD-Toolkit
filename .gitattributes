# Keep generated GitHub/source archives release-clean.
.gitignore export-ignore
.gitattributes export-ignore
.DS_Store export-ignore
__MACOSX/ export-ignore
XRD_Finder/data/ export-ignore
XRD_Finder/data/** export-ignore

# Local/runtime/generated files.
*.py[cod] export-ignore
__pycache__/ export-ignore
**/__pycache__/** export-ignore
.pytest_cache/ export-ignore
.mypy_cache/ export-ignore
.ruff_cache/ export-ignore
dist/ export-ignore
build/ export-ignore
*.egg-info/ export-ignore

# Legacy XRD Manager scaffolding is kept in the repository but not shipped in Finder source archives.
XRD_Finder/xrd_finder/app.py export-ignore
XRD_Finder/xrd_finder/core/refinement.py export-ignore
XRD_Finder/xrd_finder/core/series.py export-ignore
XRD_Finder/xrd_finder/io/exporters.py export-ignore
XRD_Finder/xrd_finder/services/refinement_service.py export-ignore
XRD_Finder/xrd_finder/services/thermo_service.py export-ignore
XRD_Finder/xrd_finder/services/solid_solution_service.py export-ignore
XRD_Finder/xrd_finder/services/structure_service.py export-ignore
XRD_Finder/xrd_finder/ui/legacy_windows.py export-ignore
XRD_Finder/xrd_finder/ui/main_window.py export-ignore
# Normalize text files across Windows/macOS/Linux checkouts.
* text=auto
*.sh text eol=lf
*.command text eol=lf
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.vbs text eol=crlf
